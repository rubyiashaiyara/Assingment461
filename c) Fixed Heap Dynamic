C++:
#include <iostream>

int main() {
    int* stack = new int[5];  // Fixed-size heap allocation
    int top = -1;

    // Push operation
    stack[++top] = 10;
    stack[++top] = 20;

    // Pop operation
    int popped = stack[top--];

    std::cout << "Popped: " << popped << std::endl;

    delete[] stack;  // Deallocate memory
    return 0;
}

