C++:
#include <iostream>
#include <vector>

int main() {
    std::vector<int> stack;

    // Push operation
    stack.push_back(10);
    stack.push_back(20);

    // Pop operation
    int popped = stack.back();
    stack.pop_back();

    std::cout << "Popped: " << popped << std::endl;
    return 0;
}

